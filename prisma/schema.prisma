generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  createdAt DateTime @default(now())
}

model Campaign {
  id          Int       @id @default(autoincrement())
  title       String
  description String?
  theme       String?
  level       Int?
  maxPlayers  Int?
  createdAt   DateTime  @default(now())
  characters  Character[]
  messages    Message[]
  combatState CombatState?
  memory      CampaignMemory?
  quests      Quest[]
}

model Quest {
  id          Int      @id @default(autoincrement())
  campaignId  Int
  title       String
  description String?
  status      String   @default("active")
  progress    String?
  reward      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  campaign    Campaign @relation(fields: [campaignId], references: [id])
}

model Character {
  id          Int      @id @default(autoincrement())
  name        String
  race        String?
  class       String?
  level       Int?
  hp          Int?
  armorClass  Int?
  strength    Int?
  dexterity   Int?
  constitution Int?
  intelligence Int?
  wisdom      Int?
  charisma    Int?
  inventory   String?
  backstory   String?
  campaignId  Int?
  campaign    Campaign? @relation(fields: [campaignId], references: [id])
  createdAt   DateTime  @default(now())
}

model Message {
  id         Int      @id @default(autoincrement())
  campaignId Int
  author     String
  role       String
  content    String
  createdAt  DateTime @default(now())
  campaign   Campaign @relation(fields: [campaignId], references: [id])
}

model CombatState {
  id         Int      @id @default(autoincrement())
  campaignId Int      @unique
  active     Boolean  @default(false)
  round      Int      @default(1)
  turnIndex  Int      @default(0)
  createdAt  DateTime @default(now())
  campaign   Campaign @relation(fields: [campaignId], references: [id])
}

model CampaignMemory {
  id                Int      @id @default(autoincrement())
  campaignId        Int      @unique
  currentScene      String?
  currentLocation   String?
  currentObjective  String?
  currentThreat     String?
  tensionLevel      Int      @default(1)
  discoveredClues   Json     @default("[]")
  activeNPCs        Json     @default("[]")
  activeEnemies     Json     @default("[]")
  storyFlags        Json     @default("{}")
  turnCount         Int      @default(0)
  lastPlayerAction  String?
  lastMasterAction  String?
  summary           String?
  lastSummaryTurn   Int      @default(0)
  updatedAt         DateTime @updatedAt
  createdAt         DateTime @default(now())
  campaign          Campaign @relation(fields: [campaignId], references: [id])
}
